{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ESNext"],
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"isolatedModules": true,
		"allowImportingTsExtensions": true,
		"resolveJsonModule": true,
		"types": ["bun", "node"]
	},
	"include": ["files/**/*.ts", "scripts/**/*.ts", "types/**/*.d.ts"]
}
