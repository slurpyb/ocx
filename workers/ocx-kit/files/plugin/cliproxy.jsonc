{
	// Required: CLIProxy base URL
	"url": "http://localhost:8317",

	// Optional: API key credential (literal | {env:VAR} | {file:PATH})
	"apiKey": "{env:CLIPROXY_API_KEY}",

	// Provider bucket IDs are fixed as cliproxy-<effective-host>.
	// No configurable prefix is supported.

	// Optional provider-level defaults keyed by provider namespace.
	"provider": {
		"anthropic": {
			"chat": {
				"headers": {
					"x-tenant": "dev"
				}
			}
		}
	},

	// Optional model-level overrides keyed by discovered model ID.
	"models": {
		"claude-sonnet-4-5-20250929": {
			"source": "anthropic/claude-sonnet-4-5-20250929",
			"displayName": "Claude Sonnet 4.5 (CLIProxy)",
			"chat": {
				"params": {
					"temperature": 0.2
				}
			}
		}
	}
}
