{
	"$schema": "https://opencode.ai/config.json",
	// Free OpenCode Zen models - no API keys required
	"model": "opencode/big-pickle",
	"small_model": "opencode/gpt-5-nano",

	"agent": {
		// Orchestrators
		"plan": {
			"model": "opencode/big-pickle",
			"temperature": 0.3,
			"reasoningEffort": "high",
			"textVerbosity": "low"
		},
		"build": {
			"model": "opencode/big-pickle",
			"temperature": 0.3,
			"reasoningEffort": "medium",
			"textVerbosity": "low"
		},

		// Implementation
		"coder": {
			"model": "opencode/big-pickle",
			"temperature": 0.2,
			"reasoningEffort": "high",
			"textVerbosity": "low"
		},

		// Specialists
		"explore": {
			"model": "opencode/gpt-5-nano",
			"temperature": 0.2,
			"reasoningEffort": "low",
			"textVerbosity": "low"
		},
		"researcher": {
			"model": "opencode/gpt-5-nano",
			"temperature": 0.4,
			"reasoningEffort": "high",
			"textVerbosity": "medium"
		},
		"scribe": {
			"model": "opencode/gpt-5-nano",
			"temperature": 1,
			"reasoningEffort": "low",
			"textVerbosity": "high"
		},
		"reviewer": {
			"model": "opencode/gpt-5-nano",
			"temperature": 0.1,
			"reasoningEffort": "high",
			"textVerbosity": "medium"
		}
	}
}
