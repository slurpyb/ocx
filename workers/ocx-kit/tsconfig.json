{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ESNext", "DOM"],
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"isolatedModules": true,
		"allowImportingTsExtensions": true,
		"resolveJsonModule": true
	},
	"include": ["scripts/**/*.ts", "types/**/*.d.ts"]
}
