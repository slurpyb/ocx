{
	"name": "ocx",
	"version": "0.0.0",
	"description": "ShadCN-style CLI for OpenCode extensions - agents, skills, plugins, commands",
	"author": "kdcokenny",
	"license": "MIT",
	"type": "module",
	"private": true,
	"packageManager": "bun@1.3.5",
	"repository": {
		"type": "git",
		"url": "https://github.com/kdcokenny/ocx.git"
	},
	"workspaces": [
		"packages/*",
		"workers/*"
	],
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"check": "turbo run check",
		"release:tag": "bun run --cwd packages/cli release:tag",
		"format": "biome check --write .",
		"test": "turbo run test",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@commitlint/types": "^20.5.0",
		"husky": "^9.1.7",
		"pkg-pr-new": "^0.0.66",
		"turbo": "^2.9.3",
		"typescript": "^6.0.2",
		"wrangler": "^4.79.0"
	}
}
